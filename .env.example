# ===========================================
# Unified Environment Variables
# Shared by both backend and frontend
# ===========================================

# --- Backend: HuggingFace ---
HF_API_KEY=hf_your_token_here
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Backend: Anthropic ---
ANTHROPIC_API_KEY=sk-ant-your_key_here

# --- Shared: Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...your_service_role_key

# --- Shared: HeyGen ---
HEYGEN_API_KEY=your_heygen_api_key

# --- Frontend: HeyGen Avatar Config ---
NEXT_PUBLIC_HEYGEN_AVATAR_ID=your_heygen_avatar_id
NEXT_PUBLIC_HEYGEN_VOICE_ID=your_heygen_voice_id

# --- Frontend: API URL ---
NEXT_PUBLIC_API_URL=http://localhost:8000
