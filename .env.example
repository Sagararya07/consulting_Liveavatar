# ===========================================
# Unified Environment Variables
# Shared by both backend and frontend
# ===========================================

# --- Backend: HuggingFace ---
HF_API_KEY=hf_your_token_here
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Backend: Anthropic ---
ANTHROPIC_API_KEY=sk-ant-your_key_here

# --- Backend: Admin auth ---
# Username/password used to sign in at /admin. Login issues a signed bearer
# token bound to ADMIN_USERNAME with a 24h expiry. The token is verified
# against ADMIN_TOKEN_SECRET (falls back to ADMIN_PASSWORD if unset).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
ADMIN_TOKEN_SECRET=replace-with-a-long-random-string
# Optional legacy shared-secret token. Only honored if ADMIN_TOKEN_SECRET
# is unset — leave blank in fresh deployments.
ADMIN_TOKEN=

# --- Shared: Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...your_service_role_key

# --- Shared: HeyGen ---
HEYGEN_API_KEY=your_heygen_api_key

# --- Frontend: HeyGen Avatar Config ---
NEXT_PUBLIC_HEYGEN_AVATAR_ID=your_heygen_avatar_id
NEXT_PUBLIC_HEYGEN_VOICE_ID=your_heygen_voice_id

# --- Frontend: API URL ---
NEXT_PUBLIC_API_URL=http://localhost:8000
